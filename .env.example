# A szerver portja (helyi futtatáshoz). cPanel/Passenger alatt a portot a
# Passenger adja, ezt a beállítást ott figyelmen kívül hagyja.
PORT=3000

# Admin panel jelszava – ÉLESBEN MINDENKÉPPEN VÁLTOZTASD MEG!
ADMIN_PASSWORD=admin123

# A felhasználói munkamenet-tokenek aláírókulcsa. Éles környezetben állíts be egy
# hosszú, véletlenszerű értéket, hogy a bejelentkezések túléljék az újraindítást.
# Ha nincs megadva, a rendszer generál egyet és a data/ mappába menti.
# AUTH_SECRET=cserELD-egy-hosszu-veletlen-ertekre

# Éles környezetben ajánlott:
# NODE_ENV=production

# --- Adatbázis ---
# DB_DRIVER: "mysql" (ajánlott cPanel-en) vagy "sqlite" (alap, helyi fejlesztéshez).
# Ha nincs megadva: mysql, ha van DB_HOST, egyébként sqlite.
# DB_DRIVER=mysql

# MySQL / MariaDB kapcsolat (a cPanel-ben a MySQL Databases alatt hozod létre az
# adatbázist és a felhasználót, majd rendeld a felhasználót az adatbázishoz).
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=felhasznalo_dbuser
# DB_PASSWORD=titkos_jelszo
# DB_NAME=felhasznalo_dornsite

# SQLite esetén opcionális: az adatbázis helye (alap: ./data).
# DATA_DIR=/home/felhasznalo/dornsite-data

# Opcionális: a feltöltött fájlok helye (alap: ./uploads). cPanel-en érdemes
# lehet a public_html-en kívülre tenni.
# UPLOAD_DIR=/home/felhasznalo/dornsite-uploads
